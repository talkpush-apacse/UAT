# Copy this file to .env.local and fill in the values
# Never commit .env.local to git

# Admin Authentication
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Email (Brevo)
# Required for the notify testers feature
# Get your key at https://app.brevo.com/settings/keys/api
BREVO_API_KEY=

# OpenAI (optional — AI UAT Summary feature)
# Required for the AI-powered UAT summary on the admin dashboard
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# MCP (optional — remote MCP server for AI agent access)
# Required for the /api/mcp endpoint used by Claude Desktop, Cursor, etc.
MCP_API_KEY=

# Sentry (optional — error monitoring)
SENTRY_DSN=
